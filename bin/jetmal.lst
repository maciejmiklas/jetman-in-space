  1+  8015              ; Loads
  2+  8015              LoadSprites:
  3+  8015 22 2D 80     	LD (.dmaSource), HL						; Copy sprite sheet address from HL
  4+  8018 ED 43 2F 80  	LD (.dmaLength), BC						; Copy length in bytes from BC
  5+  801C 01 3B 30     	LD BC, $303B							; Prepare port for sprite index
  6+  801F ED 79        	OUT (C), A								; Load index of first sprite
  7+  8021 21 2B 80     	LD HL, .dmaProgram						; Setup source for OTIR
  8+  8024 06 0E        	LD B, .dmaProgramLength 				; Setup length for OTIR
  9+  8026 0E 6B        	LD C, $6B								; Setup DMA port
 10+  8028 ED B3        	OTIR									; Invoke DMA code
 11+  802A C9           	RET
 12+  802B
 13+  802B              .dmaProgram:
 14+  802B 83           	DB %10000011							; WR6 - Disable DMA
 15+  802C 7D           	DB %01111101							; WR0 - append length + port A address, A->B
 16+  802D
 17+  802D              .dmaSource:
 18+  802D 00 00        	DW 0									; WR0 par 1&2 - port A start address
 19+  802F
 20+  802F              .dmaLength:
 21+  802F 00 00        	DW 0									; WR0 par 3&4 - transfer length
 22+  8031 14           	DB %00010100							; WR1 - A incr., A=memory
 23+  8032 28           	DB %00101000							; WR2 - B fixed, B=I/O
 24+  8033 AD           	DB %10101101							; WR4 - continuous, append port B address
 25+  8034 5B 00        	DW $005B								; WR4 par 1&2 - port B address
 26+  8036 82           	DB %10000010							; WR5 - stop on end of block, CE only
 27+  8037 CF           	DB %11001111							; WR6 - load addresses into DMA counters
 28+  8038 87           	DB %10000111							; WR6 - enable DMA
 29+  8039              .dmaProgramLength = $-.dmaProgram
