 46+  800B              SPR_NR				EQU $34			; Sprite Number (R/W)
 47+  800B              SPR_X				EQU $35			; Sprite X coordinate
 48+  800B              SPR_Y				EQU $36			; Sprite Y coordinate
 49+  800B
 50+  800B              ; bits 7-4 = Palette offset added to top 4 bits of sprite colour index
 51+  800B              ; bit 3 = X mirror
 52+  800B              ; bit 2 = Y mirror
 53+  800B              ; bit 1 = Rotate
 54+  800B              ; bit 0 = MSB of X coordinate (palette offset indicator for relative sprites)
 55+  800B              SPR_ATTR_2			EQU $37
 56+  800B
 57+  800B              ; bit 7 = Visible flag (1 = displayed)
 58+  800B              ; bit 6 = Extended attribute (1 = Sprite Attribute 4 is active)
 59+  800B              ; bits 5-0 = Pattern used by sprite (0-63)
 60+  800B              SPR_ATTR_3			EQU $38
 61+  800B
 62+  800B              ; bit 7 = H (1 = sprite uses 4-bit patterns)
 63+  800B              ; bit 6 = N6 (0 = use the first 128 bytes of the pattern else use the last 128 bytes)
 64+  800B              ; bit 5 = 1 if relative sprites are composite, 0 if relative sprites are unified Scaling
 65+  800B              ; bits 4-3 = X scaling (00 = 1x, 01 = 2x, 10 = 4x, 11 = 8x)
 66+  800B              ; bits 2-1 = Y scaling (00 = 1x, 01 = 2x, 10 = 4x, 11 = 8x)
 67+  800B              ; bit 0 = MSB of Y coordinate
 68+  800B              SPR_ATTR_4			EQU $39
 69+  800B
 70+  800B              ; Sprite and Layers system
 71+  800B              ; bit 7 = LoRes mode, 128 x 96 x 256 colours (1 = enabled)
 72+  800B              ; bit 6 = Sprite priority (1 = sprite 0 on top, 0 = sprite 127 on top)
 73+  800B              ; bit 5 = Enable sprite clipping in over border mode (1 = enabled)
 74+  800B              ; bits 4-2 = set layers priorities:
 75+  800B              ; Reset default is 000, sprites over the Layer 2, over the ULA graphics
 76+  800B              ; 000 - S L U
 77+  800B              ; 001 - L S U
 78+  800B              ; 010 - S U L - (Top - Sprites, Enhanced_ULA, Layer 2)
 79+  800B              ; 011 - L U S
 80+  800B              ; 100 - U S L
 81+  800B              ; 101 - U L S
 82+  800B              ; 110 - S(U+L) ULA and Layer 2 combined, colours clamped to 7
 83+  800B              ; 111 - S(U+L-5) ULA and Layer 2 combined, colours clamped to [0,7]
 84+  800B              ; bit 1 = Over border (1 = yes)(Back to 0 after a reset)
 85+  800B              ; bit 0 = Sprites visible (1 = visible)(Back to 0 after a reset)
 86+  800B              SPR_SETUP			EQU $15
