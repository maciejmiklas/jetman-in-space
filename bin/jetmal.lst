 31   C101              	; https://z00m128.github.io/sjasmplus/documentation.html
 32   C101
 33   C101              	CSPECTMAP "jetman.map"					; Generate a map file for use with Cspect
 34   C101
 35   C101              	; This sets the name of the project, the start address,
 36   C101              	; and the initial stack pointer.
 37   C101              	SAVENEX OPEN "jetman.nex", start, $FF40
 38   C101
 39   C101              	; This asserts the minimum core version.  Set it to the core version
 40   C101              	; you are developing on.
 41   C101              	SAVENEX CORE 2,0,0
 42   C101
 43   C101              	; This sets the border colour while loading (in this case white),
 44   C101              	; what to do with the file handle of the nex file when starting (0 =
 45   C101              	; close file handle as we're not going to access the project.nex
 46   C101              	; file after starting.  See sjasmplus documentation), whether
 47   C101              	; we preserve the next registers (0 = no, we set to default), and
 48   C101              	; whether we require the full 2MB expansion (0 = no we don't).
 49   C101              	SAVENEX CFG 7,0,0,0
 50   C101
 51   C101              	; Generate the Nex file automatically based on which pages you use.
 52   C101              	SAVENEX AUTO
