# file opened: ./src/jetman_move.asm
  1+  C0BC              MoveUp:
  2+  C0BC 3E 55        	LD A, 'U'								; Print U
  3+  C0BE CD EE C0     	CALL PrintDirection
  4+  C0C1 C9           	RET
  5+  C0C2
  6+  C0C2              MoveDown:
  7+  C0C2 3E 44        	LD A, 'D'								; Print D
  8+  C0C4 CD EE C0     	CALL PrintDirection
  9+  C0C7
 10+  C0C7              	; Update X position
 11+  C0C7 3A 13 80     	LD A, (JetX)
 12+  C0CA 3D           	DEC A
 13+  C0CB 32 13 80     	LD (JetX), A
 14+  C0CE
 15+  C0CE ED 91 34 00  	NEXTREG SPR_NR, SPR_JETMAN_ID			; Player
 16+  C0D2 ED 92 35     	NEXTREG SPR_X, A
 17+  C0D5
 18+  C0D5 3E FF        	LD A, 255
 19+  C0D7 3C           	INC A
 20+  C0D8 3C           	INC A
 21+  C0D9 18 FE        	JR $
 22+  C0DB
 23+  C0DB C9           	RET
 24+  C0DC
 25+  C0DC              MoveRight:
 26+  C0DC 3E 52        	LD A, 'R'								; Print R
 27+  C0DE CD EE C0     	CALL PrintDirection
 28+  C0E1 C9           	RET
 29+  C0E2
 30+  C0E2              MoveLeft:
 31+  C0E2 3E 4C        	LD A, 'L'								; Print L
 32+  C0E4 CD EE C0     	CALL PrintDirection
 33+  C0E7 C9           	RET
 34+  C0E8
 35+  C0E8              PressFire:
 36+  C0E8 3E 46        	LD A, 'F'								; Print F
 37+  C0EA CD EE C0     	CALL PrintDirection
 38+  C0ED C9           	RET
 39+  C0EE
 40+  C0EE              ; A - contains character to print
 41+  C0EE              PrintDirection
 42+  C0EE F5           	PUSH AF									; Keep A containing character to print
 43+  C0EF 3E 16        	LD A, PR_AT								; AT control character
 44+  C0F1 D7           	RST ROM_PRINT
 45+  C0F2 3E 01        	LD A, 1									; Y
 46+  C0F4 D7           	RST ROM_PRINT
 47+  C0F5 3E 0F        	LD A, 15								; X
 48+  C0F7 D7           	RST ROM_PRINT
 49+  C0F8 3E 10        	LD A, PR_INK							; Ink colour
 50+  C0FA D7           	RST ROM_PRINT
 51+  C0FB 3E 02        	LD A, 2									; Red
 52+  C0FD D7           	RST ROM_PRINT
 53+  C0FE F1           	POP AF									; Restore character for printing
 54+  C0FF D7           	RST ROM_PRINT
 55+  C100 C9           	RET
