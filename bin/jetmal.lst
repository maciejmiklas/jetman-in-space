 25   C061              	INCLUDE "src/game_input.asm"
# file opened: ./src/game_input.asm
  1+  C061              ;----------------------------------------------------------;
  2+  C061              ;                     Input processing                     ;
  3+  C061              ;----------------------------------------------------------;
  4+  C061              HandleJoystingInput:
  5+  C061              	; Key Up pressed ?
  6+  C061 3E EF        	LD A, KB_6_TO_0							; $EF -> A (6...0)
  7+  C063 DB FE        	IN A, (KB_REG) 							; Read keyboard input into A
  8+  C065 CB 5F        	BIT 3, A								; Bit 3 reset -> Up pessed
  9+  C067 CC BC C0     	CALL Z, MoveUp
 10+  C06A
 11+  C06A              	; Key Down pressed ?
 12+  C06A 3E EF        	LD A, KB_6_TO_0							; $EF -> A (6...0)
 13+  C06C DB FE        	IN A, (KB_REG) 							; Read keyboard input into A
 14+  C06E CB 67        	BIT 4, A								; Bit 4 reset -> Down pessed
 15+  C070 CC C2 C0     	CALL Z, MoveDown
 16+  C073
 17+  C073              	; Key Rright pressed ?
 18+  C073 3E EF        	LD A, KB_6_TO_0							; $EF -> A (6...0)
 19+  C075 DB FE        	IN A, (KB_REG) 							; Read keyboard input into A
 20+  C077 CB 57        	BIT 2, A								; Bit 2 reset -> Rright pessed
 21+  C079 CC DC C0     	CALL Z, MoveRight
 22+  C07C
 23+  C07C              	; Key Left pressed ?
 24+  C07C 3E F7        	LD A, KB_5_TO_1							; $FD -> A (5...1)
 25+  C07E DB FE        	IN A, (KB_REG) 							; Read keyboard input into A
 26+  C080 CB 67        	BIT 4, A								; Bit 4 reset -> Left pessed
 27+  C082 CC E2 C0     	CALL Z, MoveLeft
 28+  C085
 29+  C085              	; Key Fire (Z) pressed ?
 30+  C085 3E FE        	LD A, KB_V_TO_Z							; $FD -> A (5...1)
 31+  C087 DB FE        	IN A, (KB_REG) 							; Read keyboard input into A
 32+  C089 CB 4F        	BIT 1, A								; Bit 1 reset -> Z pessed
 33+  C08B CC E8 C0     	CALL Z, PressFire
 34+  C08E
 35+  C08E              	; Joystick up pressed ?
 36+  C08E 3E 20        	LD A, JOY_MASK							; Activete joystick register
 37+  C090 DB 1F        	IN A, (JOY_REG) 						; Read joystick input into A
 38+  C092 CB 5F        	BIT 3, A								; Bit 3 set -> Up pessed
 39+  C094 C4 BC C0     	CALL NZ, MoveUp
 40+  C097
 41+  C097              	; Joystick down pressed ?
 42+  C097 3E 20        	LD A, JOY_MASK							; Activete joystick register
 43+  C099 DB 1F        	IN A, (JOY_REG) 						; Read joystick input into A
 44+  C09B CB 57        	BIT 2, A								; Bit 2 set -> Down pessed
 45+  C09D C4 C2 C0     	CALL NZ, MoveDown
 46+  C0A0
 47+  C0A0              	; Joystick right pressed ?
 48+  C0A0 3E 20        	LD A, JOY_MASK							; Activete joystick register
 49+  C0A2 DB 1F        	IN A, (JOY_REG) 						; Read joystick input into A
 50+  C0A4 CB 47        	BIT 0, A								; Bit 0 set -> Right pessed
 51+  C0A6 C4 DC C0     	CALL NZ, MoveRight
 52+  C0A9
 53+  C0A9              	; Joystick left pressed ?
 54+  C0A9 3E 20        	LD A, JOY_MASK							; Activete joystick register
 55+  C0AB DB 1F        	IN A, (JOY_REG) 						; Read joystick input into A
 56+  C0AD CB 4F        	BIT 1, A								; Bit 1 set -> Left pessed
 57+  C0AF C4 E2 C0     	CALL NZ, MoveLeft
 58+  C0B2
 59+  C0B2              	; Joystick fire pressed ?
 60+  C0B2 3E 20        	LD A, JOY_MASK							; Activete joystick register
 61+  C0B4 DB 1F        	IN A, (JOY_REG) 						; Read joystick input into A
 62+  C0B6 E6 70        	AND %01110000							; Any of three fires pressed?
 63+  C0B8 C4 E8 C0     	CALL NZ, PressFire
 64+  C0BB
 65+  C0BB C9           	RET
# file closed: ./src/game_input.asm
